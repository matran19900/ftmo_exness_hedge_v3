# Required: which FTMO account this process drives.
# Must match the account_id you registered via `python -m scripts.init_account add`.
# Format: ^[a-z0-9_]{3,64}$
FTMO_ACCOUNT_ID=ftmo_acc_001

# Required: Redis connection (LAN db 2 per dev convention).
REDIS_URL=redis://192.168.88.4:6379/2

# Required: cTrader Open API app credentials.
# Apply at https://openapi.ctrader.com (one app, reused for every account).
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=

# Required: OAuth callback target. The local OAuth flow script binds an
# HTTP server here for the consent redirect; this URL must EXACTLY match
# what you registered on the cTrader app page.
CTRADER_REDIRECT_URI=http://localhost:8765/callback

# Optional: cTrader Open API gateway. Default targets the live gateway.
# CTRADER_HOST=live.ctraderapi.com
# CTRADER_PORT=5035

# Optional: log level (DEBUG|INFO|WARNING|ERROR). Default INFO.
# LOG_LEVEL=INFO
