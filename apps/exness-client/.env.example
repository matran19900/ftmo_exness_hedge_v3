# Required: which Exness account this process drives.
# Format: ^[a-z0-9_]{3,64}$ (lowercase alphanum + underscore).
ACCOUNT_ID=exness_acc_001

# Required: Redis connection (LAN db 2 per dev convention; matches FTMO client).
REDIS_URL=redis://192.168.88.4:6379/2

# Required: Exness MT5 account credentials. Apply via Exness web cabinet,
# then "Open MT5 demo / live account".
MT5_LOGIN=12345678
MT5_PASSWORD=changeme
MT5_SERVER=Exness-MT5Trial7

# Optional: path to the MT5 terminal executable. If omitted, MetaTrader5
# auto-detects the system install. Required only when multiple MT5
# builds are installed and you want to target a specific one.
# MT5_PATH=C:\Program Files\MetaTrader 5 EXNESS\terminal64.exe

# Optional: heartbeat write cadence (seconds). Default 5s; server's TTL
# of 30s allows 6 missed beats before marking offline.
# HEARTBEAT_INTERVAL_S=5.0

# Optional: XREADGROUP BLOCK timeout (ms). Default 1000ms — tight enough
# to honour shutdown signals quickly without busy-looping when idle.
# CMD_STREAM_BLOCK_MS=1000

# Optional: log level (DEBUG|INFO|WARNING|ERROR). Default INFO.
# LOG_LEVEL=INFO
