{
  "name": "FTMO Hedge v3 — Claude Sandbox",

  "image": "mcr.microsoft.com/devcontainers/python:3.12-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest"
    }
  },

  "containerEnv": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1",
    "PIP_DISABLE_PIP_VERSION_CHECK": "1",
    "TZ": "Asia/Ho_Chi_Minh",
    "REDIS_URL": "redis://192.168.88.4:6379/2",
    "SYMBOL_MAPPING_PATH": "/workspaces/ftmo_exness_hedge_v3/server/data/ftmo_whitelist.json",
    "SYMBOL_MAPPING_CACHE_DIR": "/workspaces/ftmo_exness_hedge_v3/server/data/symbol_mapping_cache"
  },

  "remoteUser": "vscode",

  "workspaceFolder": "/workspaces/ftmo_exness_hedge_v3",

  "mounts": [
    "source=hedger-claude-config,target=/home/vscode/.claude,type=volume",
    "source=hedger-bash-history,target=/home/vscode/.bash_history_volume,type=volume",
    "source=hedger-sandbox-config,target=/home/vscode/.config/hedger-sandbox,type=volume"
  ],

  "runArgs": [
    "--cap-drop=ALL",
    "--cap-add=CHOWN",
    "--cap-add=DAC_OVERRIDE",
    "--cap-add=SETGID",
    "--cap-add=SETUID",
    "--security-opt=no-new-privileges"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.mypy-type-checker",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/ftmo_exness_hedge_v3/server/.venv/bin/python",
        "python.terminal.activateEnvironment": false,
        "[python]": {
          "editor.formatOnSave": true,
          "editor.defaultFormatter": "charliermarsh.ruff"
        },
        "ruff.path": [
          "/workspaces/ftmo_exness_hedge_v3/server/.venv/bin/ruff"
        ],
        "mypy-type-checker.path": [
          "/workspaces/ftmo_exness_hedge_v3/server/.venv/bin/mypy"
        ],
        "files.eol": "\n",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "postStartCommand": "git config --global --add safe.directory /workspaces/ftmo_exness_hedge_v3",

  "forwardPorts": [8000, 5173],
  "portsAttributes": {
    "8000": {
      "label": "FastAPI server",
      "onAutoForward": "notify"
    },
    "5173": {
      "label": "Vite dev server",
      "onAutoForward": "notify"
    }
  }
}
