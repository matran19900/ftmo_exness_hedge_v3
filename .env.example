# FTMO Hedge Tool v3 — server env vars.
#
# Generate JWT_SECRET:    openssl rand -hex 32
# Generate password hash: python -c "import bcrypt; print(bcrypt.hashpw(b'admin', bcrypt.gensalt(rounds=12)).decode())"
# Default admin password is `admin`. Change before any real deployment.
#
# Settings loads this file from the repo root regardless of which directory
# uvicorn / pytest is started in (path resolved from server/app/config.py).

REDIS_URL=redis://192.168.88.4:6379/2
SYMBOL_MAPPING_PATH=/workspaces/ftmo_exness_hedge_v3/symbol_mapping_ftmo_exness.json

# CORS_ORIGINS accepts either format:
#   Comma-separated:  CORS_ORIGINS=http://localhost:5173,http://localhost:4173
#   JSON list:        CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]
CORS_ORIGINS=http://localhost:5173

LOG_LEVEL=INFO

JWT_SECRET=<generate-with-openssl-rand-hex-32>
JWT_EXPIRES_MINUTES=60
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=<bcrypt-hash-of-admin-password>
